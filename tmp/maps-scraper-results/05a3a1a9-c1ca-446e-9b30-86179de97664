s-cs-s/APNQkAHLxf2W6c8QNn94GVU6VJttp6ZX-16LJKnPPuv7X2XdntCEeanoeuDvxUbefIkG6CR9XHwmad8C2n21RhPErU0mkelaPwx9Dj499dQkJtB14F8bkySSRDLIOjvxMLSToAC0cTIk=w397-h298-k-no"},{"title":"Street View \u0026 360°","image":"https://streetviewpixels-pa.googleapis.com/v1/thumbnail?panoid=fEYbw7F4qfRKGpqSS0NPNQ\u0026cb_client=maps_sv.tactile.gps\u0026w=224\u0026h=298\u0026yaw=183.78561\u0026pitch=0\u0026thumbfov=100"}],"reservations":null,"order_online":[{"link":"https://bothelldenturedentist.com/contact/","source":"bothelldenturedentist.com"}],"menu":{"link":"","source":""},"owner":{"id":"118000601033048752221","name":"Beautiful Smiles Denture and Dental Clinic (Owner)","link":"https://www.google.com/maps/contrib/118000601033048752221"},"complete_address":{"borough":"Canyon Park","street":"22833 Bothell Everett Hwy Suite 146","city":"Bothell","postal_code":"98021","state":"Washington","country":"US"},"about":[{"id":"service_options","name":"Service options","options":[{"name":"Onsite services","enabled":true}]},{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible entrance","enabled":true},{"name":"Wheelchair accessible parking lot","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Credit cards","enabled":false}]}],"user_reviews":[{"Name":"Info @ A Smiling Heart Dentistry","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjUSetIp1PaGU1DtPAngmU1Ry69csx2XtKJEurWSoR2062Xmo9c=s120-c-rp-mo-ba2-br100","Rating":5,"Description":"Michael is truly the best denturist you can ask for. His skill, attention to detail, and dedication to his patients are exceptional. He takes the time to listen, explain every step, and makes sure the final result is not only functional but beautiful and natural. You can tell he takes great pride in his work, and it shows in the results.\n\nIf you’re looking for a clinic that combines expertise, compassion, and outstanding craftsmanship, Beautiful Smiles Denture and Dental Clinic is the place to go. I am beyond grateful for Michael and the entire team and highly recommend them to anyone seeking the very best care.","Images":null,"When":""},{"Name":"TIGRANAIR Khachatryan","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocI_uch4P3JsZsECxFn9kIlPRIAEV1DRBwUe9cT0e_JXkgA5lg=s120-c-rp-mo-br100","Rating":5,"Description":"Beautiful Smiles Denture and Dental Clinic is an incredible place where you truly feel cared for from start to finish. The staff is warm, welcoming, and always willing to go the extra mile to make sure you feel comfortable and confident.\n\nMichael is hands down the best denturist. His knowledge, precision, and passion for what he does are unmatched. He is patient, attentive, and genuinely committed to creating results that look natural and feel right. You can trust that you’re in expert hands with him.","Images":null,"When":""},{"Name":"jc storm","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjU0Mue1KhhdPQlnoQaqPAKlPdApErFIl0US9SZ4SVEqjo3Lv1R-=s120-c-rp-mo-br100","Rating":5,"Description":"Going to the dentist can be scary and cause anxiety, especially if your going in for dentures. But Michael and his team provide a calm and relaxed environment. Michael is very caring and Intentive to his patients needs. I highly recommend Michael and his team for any of your dental needs.","Images":null,"When":""},{"Name":"Reza Rahimi","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocIJmxTfs8-ke2eBhP-TQxTTeC8KeZI6hGPdKYXfdWdg6l0G=s120-c-rp-mo-br100","Rating":2,"Description":"We had a set of denture made for my grandma at this office last year. The staff and denturist were kind, and we appreciated how welcoming they were.\n\nHowever, after getting the denture, she faced difficulties with it. It was loose, and food particles kept falling on her upper denture. We were informed that this was due to bone loss, and an implant would be the best solution to fix the looseness. After seeking a second opinion elsewhere, we were told that the bite had not been measured correctly, which was likely the reason for the poor fit. Consequently, we ended up needing a completely new set of dentures.\n\nIt was disappointing to have to replace them so soon. We hope more attention is given to bite measurements for future patients to prevent similar issues.","Images":null,"When":""},{"Name":"Anahit Khachatryan","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocI6zcIv64vo9TbM1tYh0PE04jK1NnVFO8H7MivcW2thAd2g6A=s120-c-rp-mo-br100","Rating":5,"Description":"I couldn’t be happier with my experience and highly recommend Beautiful Smiles Denture and Dental Clinic especially Michael to anyone looking for outstanding denture care and beautiful results.","Images":null,"When":""},{"Name":"Lynn Anderson","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocImsTeZ6Dc4QhNLYds_4mQJh8bbQ0f-rHF_1bG6eyBV4wbNSw=s120-c-rp-mo-br100","Rating":5,"Description":"I was treated so well here the staff and Michael were very professional and very kind\nMy dentures  fit perfectly","Images":null,"When":""},{"Name":"Jennifer Cox","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVOZAyrbPzTX7wCf3h5QMmcgWW3TC7dkK02hC7mCwDlFn2whCkZ=s120-c-rp-mo-br100","Rating":5,"Description":"Hello, my name is Jennifer and I want to share my wonderful experience with Beautiful Smiles Dental. I came here on a referral, and I was honestly at the end of my rope. I have had missing teeth and a horrible smile for about 3 and a half years. I had been to several different dentists and could not find anyone to help me. I was on a budget and needed to get a partial made immediately. I couldn't take it anymore! The first visit with Micheal was a very emotional experience. I was very sad when I came to see him. But that all changed in a matter of minutes. Micheal listened to me and went out of his way to help me. He gave me a huge break on the cost of my partial and in less than 2 weeks I had my smile back! There was no one before him that was willing to work with me at all, and he did not hesitate to help me. I have been back several times for adjustments and each time he and his entire staff are so very friendly and helpful. I am always welcomed in with a smile and kindness from everyone. Whatever your dental issue, I can proudly promise you that at Beautiful Smiles Dental you will be treated kindly and fairly. I would recommend this place to anyone and everyone! These people are here to help, and they are awesome. Thank you to everyone at Beautiful Smiles Dental in Bothell! A million times, Thank you! I have my smile back!","Images":null,"When":""},{"Name":"Jennifer Cox","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjV6t36eilia0jTQFg6Rsq-zHR9ZrU_rSI1uCxAgZ5mv_aa2mDM=s120-c-rp-mo-br100","Rating":5,"Description":"Hello there and shout out to Micheal, Hoda, and the friendly staff at Beautiful Smiles in Bothell!!! I just wanted to say, thank you! You guys have been so amazing. The best thing that I’ve done for my smile was walking through your door a year ago. You guys have stuck by your word and your work. Everyone is always so friendly, supportive, and helpful. I can’t imagine where I’d be if it weren’t for your kindness and support. I can’t wait to work with you guys again for my bottom set! I’ll never go anywhere else again! Thank you for giving me my beautiful smile back!","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
