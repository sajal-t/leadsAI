ide","street":"5616 Lawndale St # A204","city":"Houston","postal_code":"77023","state":"Texas","country":"US"},"about":[{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible entrance","enabled":true},{"name":"Wheelchair accessible parking lot","enabled":true},{"name":"Wheelchair accessible restroom","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Restroom","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointment required","enabled":true},{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Credit cards","enabled":false}]}],"user_reviews":[{"Name":"Abhi Ng","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVpGXFhi-6MU0xRtdT1o8SInOXs1hfcKMnPqpbTyCdkcTbuo7kw=s120-c-rp-mo-ba3-br100","Rating":5,"Description":"Hi there! I found your Google profile and noticed you don't have a website yet, so I would love to build one for you.\n\n​I will build the entire site and give you a free domain name, and you only pay the $500 after it is fully delivered and you are completely happy!","Images":null,"When":""},{"Name":"Tina R","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjXqgDq4E_qBW-4pewsdWeAJq81XWzVmDulcxZnd2efmjQy0A-A0=s120-c-rp-mo-ba2-br100","Rating":1,"Description":"This Dentist office is absolutely HORRENDOUS. The building is outdated and they do not have an office manager available to raise concerns. After walking into the back area I took my loved one and left. Dirty and unprofessional, it seems as if they take advantage of people who have to pay out of pocket.","Images":["https://lh3.googleusercontent.com/grass-cs/ANxoTn0gWAhjIQBtAotNfeSo93z4bY4AcwlNvPF-WyZt0r6iCNui_DOiv1lP9bB8hNmiU2sHfER7NQSQnPYzUgnTqyyub-ci9yFjIbQHDh5dryO_3R9JUcVh2Kycj0xFoPw_c43o-6Nz=k-no","https://lh3.googleusercontent