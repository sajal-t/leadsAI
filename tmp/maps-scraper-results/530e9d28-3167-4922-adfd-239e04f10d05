w-yEDGcAsWHM6xdxdmwg4j0J6or1PI-5W2uZsUB9aoCbjUF6fX8zlKGelnj8O8VHN4bcfXfztcpUORv3k-DsYwc4j3xSNSnuzq-6mQdpAucgZJlKCc8ss9Nm-IlWg=w224-h298-k-no"},{"title":"Pipe","image":"https://lh3.googleusercontent.com/gps-cs-s/APNQkAEoHEUmycEyl4an93KlSmV_RX1L6ZA4jnd2G_yFPRuSG5-es_ZOHAcq05M7yk3zSI_hKWNMYXgqQZOqcR5-lUacqyutznpDtp4IiYBMsxHShS4TTiVgAW_UScgV6TgGOiJF4L6Ztw=w224-h298-k-no"},{"title":"By owner","image":"https://lh3.googleusercontent.com/gps-cs-s/APNQkAFrsa5pds6tBX6_fYtd6gkAfe9mC_6JWr0O4F2KZLt2_FnbVEDKG3eqPtujiLY1yhXPnC545L67Ubl6tsWjvvsfBZ3ahEGEa1Qcga08FICHpn4Hqu-2DbKgMZGLby1H0ZD83ZoEOw=w397-h298-k-no"}],"reservations":null,"order_online":null,"menu":{"link":"","source":""},"owner":{"id":"102029164249548467319","name":"AM-PM Plumbing and Sewer (Owner)","link":"https://www.google.com/maps/contrib/102029164249548467319"},"complete_address":{"borough":"","street":"","city":"","postal_code":"","state":"","country":""},"about":[{"id":"from_the_business","name":"From the business","options":[{"name":"Identifies as Latino-owned","enabled":true}]},{"id":"service_options","name":"Service options","options":[{"name":"Language assistance","enabled":false}]},{"id":"offerings","name":"Offerings","options":[{"name":"Repair services","enabled":true}]}],"user_reviews":[{"Name":"Mitchell Snyder","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjV11ucWx7RMNeCV53shcpyoXj74eqf66aj4fPrIEoZWSz9dgX5Udw=s120-c-rp-mo-ba4-br100","Rating":5,"Description":"I cannot say enough about the great work that Daniel and his team have done. I had to replace the pipes leading to my external spigots and it went very well. They were professional and efficient through the entire process.\nThey came out for the estimate, Daniel walked though and talked me through his recommendations and listened to my requests. They got me on the schedule quickly and came out to do the work. There was some excavation required to access a pipe so they did some digging (was expected and discussed) but they cleaned up after themselves and took care of everything.\nThere ended up being a small leak at a joint and Daniel kindly sent someone out to take a look and replaced the part at no charge.\nI will definitely be using them in the future and would recommend them to anyone I know.","Images":null,"When":""},{"Name":"Tommy Trause","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocI4PUWJzWgENp7buUZwQ55-9DmK6JQGn_MX37DxILdwRyvjTA=s120-c-rp-mo-br100","Rating":5,"Description":"I would give Daniel and his team 10 stars if I could. He was fantastic in every way. We purchased a new home in May and subsequently have had to upgrade or fix a lot of issues inherent to a 1917 craftsman! Daniel was extremely professional, prompt and helpful in every aspect of the work. I would highly recommend his crew and I will definitely use them again if new issues arise.","Images":null,"When":""},{"Name":"Stephen K","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjV_rzRpvc29kb-mrennmUpiBxwpHYlBqa7J7GQGUG8nN41RLPveyw=s120-c-rp-mo-br100","Rating":5,"Description":"We needed major sewer repair and used AMPM at the insistence of a good friend who is a contractor.\n\nDaniel and crew provided wonderful service at an impossible to beat price! (we called around)\n\nThey even identified things that needed to be fixed that other companies missed.\n\nThey were polite and did stellar work and let us know information at each step in the process.\n\nI'm recommending them to everyone!","Images":null,"When":""},{"Name":"pedro tiburcio","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjUfTtvZITd4Hpzqe05tjz4ZDGl5SG1b8BchX1fDIX-6yc_uCYY=s120-c-rp-mo-br100","Rating":5,"Description":"Daniel and his team of worker did an excellent job with the water leak in my water heater, fixing everything professionally. I am very responsive with your work and I would strong recommend am/pm. Thank you Daniel and crew awesome job!","Images":null,"When":""},{"Name":"Michelle Meyer","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVN_rNQoGGE19O1Xps3-r3Q289b6NwmBbNzfKJ22LCpRaFVZ3JI=s120-c-rp-mo-br100","Rating":5,"Description":"AM-PM has been my trusty plumbing company for many years. They re-did all the plumbing in the house many years ago and I was very happy with their professionalism and value.  More recently, I had a sewer backup and they came out same day, right at the time they said they would so I could tell my tenant when they would be there and they did a repair to get us back to being able to use the facilities.  Then they came back to do a more permanent repair once they had explain my options and the value of each one.\nI am very happy with the way AM-PM responds and how timely and accurate their work is.\nI will continue to use them for all our plumbing needs.","Images":null,"When":""},{"Name":"Rita Lindle","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjUIZpcU9JMtkVuY3xMuVbCh41NJY7ZllIzEGRjJAxCicMBVFE9kDw=s120-c-rp-mo-br100","Rating":5,"Description":"We have used Daniel and his crew for years. They are prompt, nice and do great work. AM-PM is our go to plumbing folks!    5 ⭐️ for sure!","Images":null,"When":""},{"Name":"Gary Fisher","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocLLbkRfEJaB4ozX4EA7Ie63JsPfpYM5j4je7x1Yt5am0kxQ9w=s120-c-rp-mo-br100","Rating":5,"Description":"","Images":null,"When":""},{"Name":"Mayer Goldman","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocL9yzLbwJjl5i9v9UYy6x0dHc9etSOdAqFobunIBIuAvsgzpA=s120-c-rp-mo-br100","Rating":1,"Description":"","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
