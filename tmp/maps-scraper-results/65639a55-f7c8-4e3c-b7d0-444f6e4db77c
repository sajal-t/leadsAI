vWhNk33oNEpF34Y=w529-h298-k-no"},{"title":"Street View \u0026 360°","image":"https://streetviewpixels-pa.googleapis.com/v1/thumbnail?panoid=RzQN9kUEGvK_SjNYBJ2dzQ\u0026cb_client=maps_sv.tactile.gps\u0026w=224\u0026h=298\u0026yaw=350.25098\u0026pitch=0\u0026thumbfov=100"}],"reservations":null,"order_online":null,"menu":{"link":"","source":""},"owner":{"id":"105513137098005942364","name":"Larry's Electric (Owner)","link":"https://www.google.com/maps/contrib/105513137098005942364"},"complete_address":{"borough":"Interbay","street":"1500 W Bertona St","city":"Seattle","postal_code":"98119","state":"Washington","country":"US"},"about":[{"id":"service_options","name":"Service options","options":[{"name":"Onsite services","enabled":true}]}],"user_reviews":[{"Name":"Louise Hansen","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocLVNBWDLpiXg2ruYokAYR318YFdOEiaNnHZoclf6czB4-E-Sw=s120-c-rp-mo-br100","Rating":5,"Description":"We bought our house 3yrs ago, we knew the plumbing and electrical would need upgrade, we didn't realize how extensive it would be. After being shown our old knob and tube wiring, often held together with old tape (omg) we decided on a full rewire at the time of our kitchen remodel.\nLarry often works for the contractor I am the office manager for so it was a no brainer to try and schedule with him. I trust his work.\nIt's all fun and games until they start tearing your walls apart, it's really important to have contractor you trust to not only finish the job but do it correctly the first time.\nI'm mid rewire right now and already glad that we chose Larry's Electric to do the work. Will update with photos after the kitchen is done!","Images":null,"When":""},{"Name":"Matthew Dilligan","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKBMMOA1LGe2-8sMAl4NCFktGvOb5R0EGIR6foCHKXBxVajkA=s120-c-rp-mo-br100","Rating":5,"Description":"Larry is great. I usually do all my own electrical work but we called him when a tree ripped the service entrance off our house right when we were trying to get out of town on vacation. Larry showed up on a Sunday and did some really nice, clean, and efficient work to repair that. Even better was that he made some calls to both SDCI and PSE which got us inspected, signed off, and hooked back up in a single day. Incredible service, and all for an extremely reasonable price.","Images":null,"When":""},{"Name":"jeff O'Hare","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocIIayG8JC_McpqGI8TaYpj3h7_HM5mChNnvMMv5OlNSWl92Tw=s120-c-rp-mo-br100","Rating":5,"Description":"We have worked with Larry's Electric for years for both repair/renovation projects as well as new construction.  His team has always been great to work with.  Very fair and competitive pricing and always honest and good to work with.","Images":null,"When":""},{"Name":"Sun's Properties Manager","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWunKDFJbMPn6yiRhX0ipVUbsePsRWz8e8WHVHpYkGlTgZ3gq5A=s120-c-rp-mo-br100","Rating":5,"Description":"We've been working with Larry and his team for a few years now, and they've always come through for us. Their pricing is hard to beat, and they consistently go above and beyond on every job. Highly recommend!","Images":null,"When":""},{"Name":"Steve Burnington","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocILnAPARgo1t4udL967aN8XTUstNPkdOWrTw3fOUNe5Q8wpJg=s120-c-rp-mo-br100","Rating":5,"Description":"Great service and reasonable prices. I was interested in the details of how the repair was done and Larry did an excellent job explaining. Definitely a future customer.","Images":null,"When":""},{"Name":"Shannon Newman","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjW7BKr78f1li8gHYoX9ffWlxZmp7qdrDxVK_eMWoMJmN4TeP7527Q=s120-c-rp-mo-ba3-br100","Rating":5,"Description":"Larry came out same day to check on the smallest of jobs, which we really appreciated - a broken smoke detector. He was very responsive and knowledgeable, and we look forward t