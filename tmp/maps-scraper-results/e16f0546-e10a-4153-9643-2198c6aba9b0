.googleusercontent.com/gps-cs-s/APNQkAG6wTPdWnyoG7AsqzakSEzb0W1yqOCTPNfHRaWc_66E8rkxA_38BhXSXsL4ggCQiZ5mWBI-wNAENpS6AlubvB_2t6GCUiF7O0aJFwSpSSS6hbTeSgHf5YY2slK-E_V6FJQSwFg=w224-h298-k-no-pi-0-ya92.2-ro0-fo100"}],"reservations":null,"order_online":null,"menu":{"link":"","source":""},"owner":{"id":"101782227168281500166","name":"Spicewood Dental (Owner)","link":"https://www.google.com/maps/contrib/101782227168281500166"},"complete_address":{"borough":"Stillhouse Springs","street":"4807 Spicewood Springs Rd #1250","city":"Austin","postal_code":"78759","state":"Texas","country":"US"},"about":[{"id":"service_options","name":"Service options","options":[{"name":"Onsite services","enabled":true},{"name":"Language assistance","enabled":false}]},{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible entrance","enabled":true},{"name":"Wheelchair accessible parking lot","enabled":true},{"name":"Wheelchair accessible restroom","enabled":true}]},{"id":"offerings","name":"Offerings","options":[{"name":"Cosmetic dentistry","enabled":true},{"name":"Emergency services","enabled":true},{"name":"Pediatric care","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Restroom","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointment required","enabled":true},{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Checks","enabled":true},{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Payment plans","enabled":true},{"name":"Credit cards","enabled":false}]},{"id":"parking","name":"Parking","options":[{"name":"Free parking lot","enabled":true}]}],"user_reviews":[{"Name":"Donna M","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocJTfNM3lf5wBNA7cScrWQmiH72YQlE7Ns2h2G5CHfcN_YnLyA=s120-c-rp-mo-br100","Rating":5,"Description":"⭐⭐⭐⭐⭐\n\nI always have a wonderful experience at Spicewood Dental! The entire team is amazing—professional, friendly, and truly caring. They do an excellent job and make sure you feel comfortable every step of the way. You can tell they genuinely care about their patients. I highly recommend them to anyone looking for great dental care in Austin!","Images":null,"When":""},{"Name":"Laura Fletcher","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjX-RFHXYXAWnLTgBm9a5o39N3-4TKVQGYQxBuw5GmQgZxl-q_AEtQ=s120-c-rp-mo-ba2-br100","Rating":5,"Description":"Dr. Owen and his team are great! Professional and kind every time we come in and they do awesome work. The office is clean and well decorated and all of the staff is friendly and knowledgeable!","Images":null,"When":""},{"Name":"Andrea Weissenbuehler","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocLwpPS2OMubWJNngR3PABJqxOTvVmcmNPiaFJaNZ7m-CxdE2Q=s120-c-rp-mo-br100","Rating":5,"Description":"After going to several dentists with mixed results, I had overcome my past experiences with offices that were truly not focused on providing good care or flat out dishonest. A friend recommended Spicewood Dental. I am relieved that I was met with a supportive staff who helped me address my fears and fix some issues. A crown was made for me, replacing one that not only caught lots of food, it was also a poor fit. I was resigned to living with it – only to find out modern technology (in their office!) could make a replacement that fits much better and I now have far less flossing to do. The staff here are patient-focused and make every effort to provide excellent care.","Images":null,"When":""},{"Name":"Rachel Y Johnson","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKK8gIW6KdWQ1ZhaRtAAPbKOLAPngsZUadmOwg5GdkLAj-l-A=s120-c-rp-mo-br100","Rating":5,"Description":"Ive been very pleased with this dental practice. The staff is always super friendly and accommodating, and able to answer any questions. The physical office space is nice, the waiting room is very comfortable, not that the wait to be seen is ever more than 2-3 minutes. The waiting room also offers chilled bottles of water and topo Chico, perfect for combating the texas heat.","Images":null,"When":""},{"Name":"Emily Schnurer","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWs6XzLluLrc9-lluJDMdhiiGY_oNYsTKlrTQvW-T6NGagOEe70=s120-c-rp-mo-br100","Rating":5,"Description":"This was my first time coming here \u0026 I felt so welcome and informed by all of the staff! Genuinely some of the kindest people I've ever had the pleasure of meeting! Extremely personable \u0026 helpful. Would recommend to anyone who wants a dental staff that cares about how they interact with their patients \u0026 the amount of information they receive about how to take care of their teeth!","Images":null,"When":""},{"Name":"Walter Ivie","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjXgtDIWDNxnl78IlEZUg4oT3SCPX64Ca61_RkjdZJs9OAYJZtIK=s120-c-rp-mo-br100","Rating":5,"Description":"The office arranged for me to get I n on short notice.  After taking x-rays they referred me to an endodontist who was able to see me the same afternoon.  Unbelievably quick service had me home and well in a few hours.","Images":null,"When":""},{"Name":"Gretchen Doyle","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWRnBDj7tMlTLa6okvrDFWuOcNgaLt3VJ1KwlFZ7ZsZg9uTB9El=s120-c-rp-mo-ba4-br100","Rating":5,"Description":"We love Spicewood Dental! Everyone is calm and caring. Brenda remembers small details about our family, Sarah remembers details about my life (chickens!) and Susan is gentle and friendly with our anxious daughter. We'd had our daughter (age 13) at another family dentist for years but decided to go ahead and transfer her here to to have all our dental care at the same place. The previous dentist had specifically said he didn't see any need for a consult about braces for her. Well, on the first visit at Spicewood Dental, Susan recommended a referral for an ortho consult. As it turns out, our daughter had a definite need for braces and even a palate expander! How did her previous dentist not see this?? I highly recommend Spicewood Dental for their caring environment and knowledgeable staff!","Images":["https://lh3.googleusercontent.com/grass-cs/ANxoTn0ZFRTzEccq_l4JMsi7iqGU5rGz3QDmcmHWotOHKZtUgtAzXE_EIIb0WdZO0TVAk37RnaHP6x8k5AR0aQ1uDwFKwX1_K65ZQ0dWFEId0P7J4jEoFHIQZu8XE4PoFcWZVycHEJkh=k-no"],"When":"2024-6-17"},{"Name":"Matthew Hildebrand","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWOGAihcVYTG8v4oM8ivqN19yLJ5bQwXyKqZ88Y8lXD27xde5O8=s120-c-rp-mo-br100","Rating":5,"Description":"Very clean thorough job and the kinda place you walk into and there's just a naturally good atmosphere and attitude. Best dentist I've ever had","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
