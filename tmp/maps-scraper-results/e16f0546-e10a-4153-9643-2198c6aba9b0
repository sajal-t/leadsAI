b_client=maps_sv.tactile.gps\u0026w=224\u0026h=298\u0026yaw=255.28108\u0026pitch=0\u0026thumbfov=100"}],"reservations":null,"order_online":[{"link":"https://online-scheduling-portal.prm.pattersondental.com/?practice=dfa14412-a93c-43f8-f6a4-08dd1ea561a2","source":"pattersondental.com"}],"menu":{"link":"/url?q=https://www.dentalcentreaustin.com/our-services.html\u0026opi=79508299\u0026sa=U\u0026ved=0ahUKEwiY2YGwkcuUAxVxweYEHX1gK8oQqRkIHygS\u0026usg=AOvVaw3FLiz9s0vAZkKohNZ_0AP_","source":"dentalcentreaustin.com"},"owner":{"id":"115571989172980312388","name":"The Dental Centre (Owner)","link":"https://www.google.com/maps/contrib/115571989172980312388"},"complete_address":{"borough":"Oak Hill","street":"4301 W William Cannon Dr # 240","city":"Austin","postal_code":"78749","state":"Texas","country":"US"},"about":[{"id":"service_options","name":"Service options","options":[{"name":"Onsite services","enabled":true},{"name":"Language assistance","enabled":false}]},{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible parking lot","enabled":true},{"name":"Assistive hearing loop","enabled":false},{"name":"Wheelchair accessible entrance","enabled":false},{"name":"Wheelchair accessible restroom","enabled":false},{"name":"Wheelchair accessible seating","enabled":false}]},{"id":"offerings","name":"Offerings","options":[{"name":"Cosmetic dentistry","enabled":true},{"name":"Emergency services","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Gender-neutral restroom","enabled":true},{"name":"Restroom","enabled":true}]},{"id":"crowd","name":"Crowd","options":[{"name":"LGBTQ+ friendly","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointment required","enabled":true},{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Payment plans","enabled":true},{"name":"Credit cards","enabled":false}]}],"user_reviews":[{"Name":"CHRISTIAN STOOPEN PALAZUELOS","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWqIU8iJ_-3kBXDeSg1KXCQ4Oc2xSBbGKpjFIY8-g-iwNQEpX0f=s120-c-rp-mo-br100","Rating":5,"Description":"Wonderful experience from start to finish. The team was warm and welcoming the moment I walked in, making check-in easy and stress-free. Dr. Fan was professional, caring, and took the time to explain everything clearly. The entire staff was friendly and attentive, and the checkout process was quick and smooth. Highly recommend Dr. Fan and the whole dental team for excellent care and service.","Images":null,"When":""},{"Name":"EJ Park","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjXPNw5fhogKqWqD7dIVr7V0US8AjII5c-cnj72PggatvjSi9GVK=s120-c-rp-mo-br100","Rating":2,"Description":"Nice office, but I hope the cleaning experience can be improved.\n\nThis was the first dental office I’ve visited in the U.S. where a cleaning took less than 15 minutes. There was no gum exam, just a very quick cleaning and done, which felt rushed and incomplete.\n\nAnother uncomfortable experience was having to ask for a goodie bag every time. On one visit, a staff member laughed and said they didn’t have toothpaste or floss and asked if I still wanted it. I said yes, and it was given to me while laughing. I’m not sure why this was treated as something laughable.\n\nConsidering patients are charged if they are late, it was also disappointing that I once waited about 20 minutes, only to receive a very short cleaning.\n\nI’m not sure if I will return, but I hope these issues can be addressed and improved.","Images":null,"When":""},{"Name":"Terrence Trujillo","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWGURnBdHChfWB0SC8yT9irrlXCwt_lTsN7DCMsOk6V1kaXfdB1=s120-c-rp-mo-br100","Rating":5,"Description":"Josh Martinez was amazing! This was hands down the best experience I’ve had for a routine cleaning. It was my first visit to this office, so I needed X-rays and a full cleaning—everything was fast, efficient, and completely pain-free. Couldn’t be happier. Thank you!","Images":null,"When":""},{"Name":"Yue Wang","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjUBg30GwakRLcaxjhewHt6qqm5ZZI32BOjACT3GpJMESWOf2HjH=s120-c-rp-mo-br100","Rating":5,"Description":"Had an excellent experience at The Dental Centre. The team was incredibly friendly. I was specifically impressed with the cleaning—they did an amazing job removing the stains on my teeth, and they look better than they have in a long time! Highly recommend Dr. Fan and his staff for their professional and positive attitude.","Images":null,"When":""},{"Name":"Angela Chung","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKqttO3xqWWMsqzltKWBvlJkd1j8og3QnpJuthu9Pw5y6ti0A=s120-c-rp-mo-br100","Rating":2,"Description":"I was a patient here for several years after moving to the U.S. and clearly told the office about my prior periodontal disease and past periodontal surgery. I maintained regular cleanings and repeatedly reported gum swelling (front tooth and molar area) over the past year.\n\nMy experience was that my symptoms were managed conservatively (e.g., mouthwash/desensitizing treatment and ‘come back in a couple of weeks’) rather than being escalated to a comprehensive periodontal reassessment or early specialist referral. After changing providers and seeing a periodontist, I was diagnosed with advanced periodontal pocketing in a molar requiring extraction and additional treatment.\n\nUpon reviewing my records, I did not find documentation of comprehensive annual periodontal charting, which I would have expected given my history.\n\nWhile routine visits were completed, I wish there had been more structured periodontal monitoring and earlier specialist involvement.\n\nI have since transitioned my care elsewhere.","Images":null,"When":""},{"Name":"Pamela Rogers","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWKMg1ERe5FGVwwlUgIL02_LZZdKZt4NYAlP8WGPvORXikDXNs=s120-c-rp-mo-br100","Rating":5,"Description":"I’m very impressed with Dr. Fan and his staff. I highly recommend him after today’s deep cleaning followed by fixing a couple of cavities. Of course, they numbed me and then I had two very minimal injections in the gum. His assistant was very nice and professional. Overall, a very pleasant experience and not painful at all. I made a follow-up appt in four months.","Images":null,"When":""},{"Name":"Hui Lin","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocII-L6mN3CLNBSbafTj-K4StA03XKO3ty4PPzk5a72gy9lxCA=s120-c-rp-mo-ba2-br100","Rating":5,"Description":"Doctor Fan saved my tooth! I broke one of my front teeth accidentally. Dr. Fan's clinic made an effort to squeeze me in next day. I though it would be a big job with many trips to fix the tooth. Dr. Fan was able to use the original crown and fix my tooth with one visit!\nDr. Fan is professional and knowledgeable. His assistant is experienced and fun. The front desk receptionist is friendly and efficient. I just started with this clinic for my dental care, and am planning to stay for many years to come.","Images":null,"When":""},{"Name":"Tainea Bayo","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjUVNlAlh3HT2v-HxDLVEmeaEZdatWC7a2EgISP4T-fU3yWvpJs6=s120-c-rp-mo-ba2-br100","Rating":5,"Description":"Mark is an amazing Hygienist he educated me on everything teeth. I had never had a cleaning that good. The dentist was very knowledgeable  as well. I highly recommend this place if you are in the Austin area.","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
