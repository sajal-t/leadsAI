s-s/APNQkAHTDNVSh2XsWG0GF_sF2LaTD40kWZ2Dn_opXfACA4mMUWCt2CVYgnMi3KP9nZ_ew31944v2zCMvh3CDC88da90QOH20PdKOjIQPPz38SzLdbYKlnva5MllKvF-WaCAeeSAyUchR=w224-h298-k-no"},{"title":"Street View \u0026 360°","image":"https://streetviewpixels-pa.googleapis.com/v1/thumbnail?panoid=3c6blzeMtKSHmJtNjrlV6g\u0026cb_client=maps_sv.tactile.gps\u0026w=224\u0026h=298\u0026yaw=34.941315\u0026pitch=0\u0026thumbfov=100"}],"reservations":null,"order_online":[{"link":"https://appt.akdentalatx.com/","source":"akdentalatx.com"}],"menu":{"link":"","source":""},"owner":{"id":"118368751977217777891","name":"AK Dental of Austin (Owner)","link":"https://www.google.com/maps/contrib/118368751977217777891"},"complete_address":{"borough":"Jollyville","street":"Land Mark: Above Lamps Plus, Near The Cheesecake Factory, 10000 Research Blvd STE 260","city":"Austin","postal_code":"78759","state":"Texas","country":"US"},"about":[{"id":"from_the_business","name":"From the business","options":[{"name":"Identifies as women-owned","enabled":true}]},{"id":"service_options","name":"Service options","options":[{"name":"Onsite services","enabled":true},{"name":"Language assistance","enabled":false}]},{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible entrance","enabled":true},{"name":"Wheelchair accessible parking lot","enabled":true},{"name":"Wheelchair accessible restroom","enabled":true},{"name":"Wheelchair accessible seating","enabled":true}]},{"id":"offerings","name":"Offerings","options":[{"name":"Emergency services","enabled":true},{"name":"Pediatric care","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Gender-neutral restroom","enabled":true},{"name":"Restroom","enabled":true}]},{"id":"crowd","name":"Crowd","options":[{"name":"LGBTQ+ friendly","enabled":true},{"name":"Transgender safespace","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Payment plans","enabled":true},{"name":"Credit cards","enabled":false}]}],"user_reviews":[{"Name":"Jacob Olivarez","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKwY_poR2hOANiWKxD11XFPtMHJBwKuhPxDzQ76Dqum0KuF=s120-c-rp-mo-br100","Rating":5,"Description":"Had an awesome experience at AK Dental! The new place looks great—super clean, modern, and honestly just really comfortable. The massage chairs alone make the visit worth it. 😄\nDr. Nekkanti is amazing. She’s super kind, easy to talk to, and really professional. She explains everything in a way that actually makes sense and makes you feel totally at ease.\nThe staff is awesome too—everyone’s friendly and helpful from the moment you walk in.\nDefinitely recommend AK Dental if you’re looking for a great dentist and a relaxing experience!","Images":null,"When":""},{"Name":"Sabanaz Shaik","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocIhP1vr7esPHdBqQEbgqMlTVLCnxla-zUzPDOK_FWa5Ll3B0Q=s120-c-rp-mo-br100","Rating":5,"Description":"Hi, my name is Sabanaz Shaik, and I had a truly wonderful experience at this dental office. Dr. Devisree is an amazing dentist—she cleaned my teeth very carefully and gently, without any pain at all. She explained everything clearly and prescribed the right treatment for me. Her knowledge, skill, and experience in dentistry really show in her work.\n\nAs a pregnant patient, I was treated with so much care and kindness. Dr. Devisree made me feel comfortable and safe, and she answered all my questions with great patience. She truly treated me like a princess and took excellent care of my teeth. Now I feel confident with a beautiful, healthy smile.\n\nI would also like to thank Elsa and Marie at the front desk. They are so friendly, helpful, and professional. From check-in to check-out, the whole team made my visit smooth and pleasant.\n\nThis clinic has an excellent team, and I highly recommend Dr. Devisree and her staff to anyone looking for gentle, professional, and caring dental care. 😊❤️","Images":null,"When":""},{"Name":"Archana Jasthi","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocL_CMcsGgTU7ew3xvmaliGktsIWU2327wPyq4GKGTnRSgqUqQ=s120-c-rp-mo-br100","Rating":5,"Description":"Dr Nekkanti is an excellent dentist—highly skilled, professional, and extremely caring. Dr Nekkanti's team take the time to explain procedures clearly and always provide valuable suggestions for long-term dental health. They are especially wonderful with kids, making them feel comfortable and at ease during visits. Their kindness and patience truly stand out, particularly in how gently they help ease pain. Highly recommend to anyone looking for a trustworthy and compassionate dentist.","Images":null,"When":""},{"Name":"Keyla Vargas","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjXXmACBKbbX99g5KdNS7MS5jIU1DClQWLp6id_fyX0FfRvFY50=s120-c-rp-mo-br100","Rating":5,"Description":"My husband and I were blown away by the exceptional care we received from Dr. Nikkanti. She made us feel completely comfortable, took the time to explain everything clearly, and treated us with such warmth that it felt like visiting family. Her clinical expertise is evident, but what truly stands out is her compassion. The entire staff reflects her values — friendly, professional, and incredibly supportive. This is by far the best dental experience we’ve ever had. Highly, highly recommend Dr. Nikkanti and her team!","Images":null,"When":""},{"Name":"Alaka Halder","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocK9xe9CzZMFjsaovs4RBcTg2BHknM6OncWCH3kq1RUtu9cVsKvr=s120-c-rp-mo-br100","Rating":5,"Description":"Dr. Nekkanti and her team were great. Unlike other dental practices I’ve visited over the past decade, she spent a lot of time with me, even though I was just there for a routine cleaning, and didn’t push any unnecessary procedures or products.\n\nShe also took care of a small cavity and walked me through where it was and the nature of its severity. I’ve had bad experiences in the past with dentists finding “ghost” cavities that a second opinion later ruled out, so I really appreciated the transparency. I’ll be back.","Images":null,"When":""},{"Name":"Darcey Cooley","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocK1Smuf3nKFET6zHvwVX3CZWinTey34l4-W3BtizP6lixpFqg=s120-c-rp-mo-br100","Rating":5,"Description":"Dr, Nekkanti couldn't have been nicer or more helpful regarding my broken tooth, Even though due to my medications she had to refer me to a specialist, I WILL be going back for regular dental care. Also has super friendly staff. I highly recommend this dental practice.","Images":null,"When":""},{"Name":"Falicovscaia Alexandra","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKBbRZk9SVwm16a_XlxejQLrjiWewPVij36URj3fac980PErBtr=s120-c-rp-mo-br100","Rating":5,"Description":"I had a great experience at this dental office. The quality of care is excellent, and the entire team is very friendly and welcoming. The dental assistants are attentive and kind, and they truly make you feel comfortable throughout the visit.\nThe doctor explains every step with great patience, which really helps put you at ease. I would especially like to mention Tina, who was incredibly patient.\nI highly recommend this office to anyone looking for high-quality dental care in a warm and professional environment.","Images":null,"When":""},{"Name":"Krunal Varajiya","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjUjuOG3TXDx6nTHCDywCEz2H2KTm4jPKVGVf7dZsdkdTvV_lUEJ=s120-c-rp-mo-br100","Rating":5,"Description":"I had such a great experience with Dr. Nikkanti! I’m usually very sensitive when it comes to dental work, but she was so gentle, caring, and patient during my deep cleaning. She made me feel completely comfortable the whole time. Her staff were also amazing — super friendly and attentive. I’m so glad I found this office and highly recommend Dr. Nikkanti and her team!","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
