_client=maps_sv.tactile.gps\u0026w=224\u0026h=298\u0026yaw=99.7602\u0026pitch=0\u0026thumbfov=100"}],"reservations":null,"order_online":[{"link":"https://nexhealth.info/book/appt/tdhtx?lid=102872\u0026rwg_token=AFd1xnHq63lSmaKzqeT3GjNVhBvvd8DsDHvsuvPnb7PGwvJfzAve3boXBnnLi8oXaEJSuxegTKKU5Qu4-vCUQbKovHTVJm8JKA%3D%3D","source":"nexhealth.info"}],"menu":{"link":"/url?q=https://www.daybreakdentalcare.com/services%3Futm_source%3Dgmb%26utm_medium%3Dorganic%3DGMB\u0026opi=79508299\u0026sa=U\u0026ved=0ahUKEwjOr565kcuUAxV01uYEHciyGc8QqRkIHygS\u0026usg=AOvVaw3pilNL-hHXQZL49c-n4vzb","source":"daybreakdentalcare.com"},"owner":{"id":"106453492488439894439","name":"Daybreak Dental (Owner)","link":"https://www.google.com/maps/contrib/106453492488439894439"},"complete_address":{"borough":"Greater South River City","street":"3801 S Congress Ave #106","city":"Austin","postal_code":"78704","state":"Texas","country":"US"},"about":[{"id":"service_options","name":"Service options","options":[{"name":"Onsite services","enabled":true},{"name":"Language assistance","enabled":false}]},{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible entrance","enabled":true},{"name":"Wheelchair accessible parking lot","enabled":true},{"name":"Wheelchair accessible restroom","enabled":true}]},{"id":"offerings","name":"Offerings","options":[{"name":"Cosmetic dentistry","enabled":true},{"name":"Emergency services","enabled":true},{"name":"Sedation dentistry","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Restroom","enabled":true}]},{"id":"crowd","name":"Crowd","options":[{"name":"LGBTQ+ friendly","enabled":true},{"name":"Transgender safespace","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointment required","enabled":true},{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Credit cards","enabled":false}]},{"id":"parking","name":"Parking","options":[{"name":"Paid parking lot","enabled":true}]}],"user_reviews":[{"Name":"Armaan Waland","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocJx_6Ke3wIPno9a8SW9xGuC2HfwHHRzDhj6kSPCD0p9LbEH7w=s120-c-rp-mo-br100","Rating":5,"Description":"I had such a great experience with Krissa at Daybreak Dental in Austin. From the moment I walked in, she made me feel comfortable and genuinely cared for. Going to the dentist can be stressful, but she has such a calm and reassuring presence that it honestly made the whole visit smooth and easy.\n\nShe was very thorough, explained everything clearly, and made sure I understood what was going on before moving forward. I never felt rushed, and she took the time to answer my questions. You can tell she really cares about her patients and takes pride in her work.\n\nIf you’re looking for someone who is professional, kind, and detail-oriented, I definitely recommend booking with Krissa at Daybreak Dental.","Images":null,"When":""},{"Name":"Brian M","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVwh867eZn918fl-V-PSovTLoxipAH54RAF8nAyWrWxINHDt7JO=s120-c-rp-mo-ba4-br100","Rating":1,"Description":"While the staff is very nice, my experience over all was not what I'd expect from a dental office. I have specific circumstances that require things done a certain way to continue to keep the integrity of my teeth. No notes were taken or entered and this lead to an unpleasant 2nd visit/cleaning. Followed by billing issues and a general feeling of disregard I cannot say I would return.","Images":null,"When":""},{"Name":"Julie Koidin","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVmjwSRRpB7-7zpieQaf_hxCe1vZd3N11lP1ueoP69GHqexwQ=s120-c-rp-mo-ba2-br100","Rating":5,"Description":"Have been putting off getting a crown for years.   I didn't quite \"trust\"/get a good vibe from the previous providers at Daybreak, but when I met Dr. Singh, I just knew I could trust her.   I chose Dr. Rausch initially because he went to Northwestern Dental School which is where my sister trained (in hygiene) and I was familiar with the academic quality.   I left my lifelong dentist when I moved to Austin and for 5 years have not found a dentist in town that I trusted as everyone (I met) in town oversells and is \"crown-happy.\"   I'd like Dr. Singh to be my \"forever dentist.\"  She's the one!  I knew the crown was necessary as my brother is a dentist and the writing was on the wall.  Dr. Singh was painless - even the initial numbing injection with that looong needle was absolutely fine due to the face massage they do at the same time to take your mind off of it.   Unfortunately, the practice changes practitioners often, which is of concern - and others have mentioned it in their Google reviews.   I had loved Liz, my hygienist for 4 years, but she's gone and there's another one.  I had a cleaning by a temp hygienist a few months ago and she might as well have been using an ice pick to clean my teeth - she was so rough and heavy-handed.  Luckily she's gone.   I'm not fond of the new protocol of polishing the teeth prior to the cleaning and by someone who isn't a trained/licensed hygienist.   To my knowledge the polishing comes after the scaling in order to smooth out the enamel, then comes the flossing to get out the paste the polishing leaves behind.  Usually a dr's office will send letters to patients when there's a change in providers.   I'm hoping that Dr. Singh will stay with the practice.   I was told to do the crown soon - in Jan. as she wouldn't be there over the summer...  Office is very clean and \"relaxing\" (for a dental office) and the procedure of a crown is done in a private room - not in one of those group areas like the big box dental places have.   Staff is great and so helpful - thank you, ladies!!","Images":null,"When":""},{"Name":"Chelsey Arambula","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVsBU_yMz3RwptBq930cLH1N0k-UgtCjJj-kCq3e8uat4l0TlI8=s120-c-rp-mo-ba3-br100","Rating":3,"Description":"I scheduled this appointment expecting to continue care with Dr. Plagenz, whom I had seen since 2022. I made this appointment during my previous visit and was not notified in advance by email or text that there was a change in providers. They reminded me that I had an appointment but failed to mention my Dentist had left/changed.\n\nThe cleaning itself was much different that I had ever experienced in the past. Three different people were involved: one completed my X-rays and polishing, another performed the scaling, and a new dentist conducted am oral/throat exam and provided feedback. It was concerning that despite multiple people examining my teeth, no one flossed them.\n\nI will say the staff were friendly and the appointment reminders were effective, the overall cleaning just wasn't what I had been getting in the past.","Images":null,"When":""},{"Name":"Shivani Jariwala","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKqkkBdsArT3pIrxWzz-UD9ZuXVOjL4YsEcvXkAyIlQZXeCf80=s120-c-rp-mo-br100","Rating":5,"Description":"I had a great experience at Daybreak! Amazing staff and even more amazing dental service. Would recommend to anyone to come here! Loyal customer here! :)","Images":null,"When":""},{"Name":"Lin D.","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKWoGeBxpRDS0CBeBjorhixNmj_Ws8OXrWynVxQRYtZmdYABi_x=s120-c-rp-mo-ba3-br100","Rating":3,"Description":"I came here and saw Dr. Plagenz the beginning of 2025. I made an appointment in August and they didn't tell me she left. which is fine, since I only saw her that one time. If a  Dr. leaves a practice you should probably let your patients know. I was going to come back in to see her for a crown before the end of this year.\n\nMy cleaning service last week was bizarre. The dental hygienist was double booked. So they had one person start with my polish and flossing first, then the actual cleaning came after, by the hygenist. Also, I've never had a place charge me for fluoride ($30) for a routine cleaning, which I opted out of.  I think they do up charge here. The prices I get quoted for on certain services are higher than my dentist back home in Houston with the same exact insurance.\n\nThe staff is really nice. They are great with reminder calls and text. It is unlikely I will return here. It's hard to transition to a new clinic when you've been used to the same dentist and top notch care and reasonably priced services,  for over 15 years.","Images":null,"When":""},{"Name":"Carla Melo-Kushaney","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjUIWOwe78Xs7X4nRdbTsbtBsWXE9sW0QlQ352n-hkgJmLImx3Gi=s120-c-rp-mo-ba4-br100","Rating":1,"Description":"I was a loyal patient of Dr. Rausch for over 10 years, even driving from Liberty Hill to South Austin because I trusted him. A few years ago I got 8 composite veneers, and when one was damaged, he replaced it with porcelain without telling me. Ever since, my two front teeth have looked completely mismatched.\n\nWhen I raised this years later, staff confirmed it after checking my records. But at my appointment today—when I asked again before fixing them—they denied it ever happened, and Dr. Rausch himself apparently claimed I never had a front veneer replaced. That is simply false, and the difference between the two veneers is obvious to anyone, you don't have to be dentist to notice it.\n\nI left enraged at the dishonesty and lack of accountability. Mistakes happen, but covering them up is unacceptable. I would strongly warn anyone considering this office: do not go here.","Images":null,"When":""},{"Name":"Hayley Martin","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocIiJdbCvKxBpOtLDNDh8n43N8A9pBFh15zguaeEEO79qV8x4Q=s120-c-rp-mo-ba3-br100","Rating":5,"Description":"Dr. Raina Singh is awesome. First of all she believed me right off the bat when I said I am super sensitive and she extra numbed me. She made sure I was completely numb before even touching me. For the first time in probably ever I didn't feel like I was being accused of being a hypochondriac or being a weenie about pain.\nSecond she helped walk me through options to figure out what my problem was. While we didn't get an answer we ruled out a few and she was very keen to refer me to a specialist to get answers. Despite there being no physical sign on the tooth or with the X-ray Dr. Singh believes my tooth pain is real. I think it would be easy for her brush it off but she repeatedly fit me into the schedule to try and fix the issue.\nThe staff and Dr. Singh are doing a lot to reduce my anxiety and also understand my insurance. I know that I will not feel unnecessary pain and that my concerns will be listened to when I see Dr. Singh.","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
