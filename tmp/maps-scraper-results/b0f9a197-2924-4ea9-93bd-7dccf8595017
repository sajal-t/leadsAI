.googleusercontent.com/gps-cs-s/APNQkAH1ln4eMfcweCXoyny24JSZucEOjqxEgLYIOm6hPk_UGahp-53q_ScPtc4x2Of60miGLb8QX62NETv8qjNW-RTCYP3uADgGKxvRcXHxwpitm4VpRVYFYnAZaYrYOpF0UEt-qcF5Lg=w529-h298-k-no"},{"title":"Street View \u0026 360°","image":"https://streetviewpixels-pa.googleapis.com/v1/thumbnail?panoid=WNrtayBX6UHrKpHK99XfJg\u0026cb_client=maps_sv.tactile.gps\u0026w=224\u0026h=298\u0026yaw=193.63731\u0026pitch=0\u0026thumbfov=100"}],"reservations":null,"order_online":[{"link":"https://icondentalcenter.com/seattle-dental-office/?utm_source=gmb\u0026utm_medium=organic","source":"icondentalcenter.com"}],"menu":{"link":"","source":""},"owner":{"id":"116452595155343761216","name":"Icon Dental Center (Owner)","link":"https://www.google.com/maps/contrib/116452595155343761216"},"complete_address":{"borough":"Belltown","street":"2815 2nd Ave #101","city":"Seattle","postal_code":"98121","state":"Washington","country":"US"},"about":[{"id":"from_the_business","name":"From the business","options":[{"name":"Identifies as women-owned","enabled":true}]},{"id":"service_options","name":"Service options","options":[{"name":"Onsite services","enabled":true}]},{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible entrance","enabled":true},{"name":"Wheelchair accessible parking lot","enabled":true},{"name":"Wheelchair accessible restroom","enabled":true}]},{"id":"offerings","name":"Offerings","options":[{"name":"Cosmetic dentistry","enabled":true},{"name":"Emergency services","enabled":true},{"name":"Pediatric care","enabled":true},{"name":"Sedation dentistry","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Restroom","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointment required","enabled":true},{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Credit cards","enabled":false}]}],"user_reviews":[{"Name":"Abhi","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjXKP_VaHqpLjb4bkkzeFrHFadYRDgPL0cO818-UfKM6sS5dU03QNw=s120-c-rp-mo-ba3-br100","Rating":5,"Description":"I’ve been a regular at Icon Dental Center for four years and fully trust them with my dental care. From fillings and cleanings to a successful two-year teeth alignment with Dr. Sohrabi, every experience has been positive. Dr. Aboulhosn, Dr. Valentine, and Dr. Hamzey have all provided excellent care and I always appreciate the friendly conversations, and Yasmina at the front desk is always friendly and helpful staying on top of scheduling needs. The support staff - hygienists, assistants, etc and the backend finance team are all attentive and responsive, kindly acknowledging and auditing an overcharge billing issue I once found in my past records.\n\nWhile there have been occasional issues over the years, what stands out is how Icon Dental Center always listens and makes things right. That dedication has truly earned my trust and the reason why I continue to be a customer here.","Images":null,"When":""},{"Name":"David Knight","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVnN-i-UE0VL7DQh1rbee4aT0A-nhaHnX7t7igSuj3UNxHy3SGN=s120-c-rp-mo-ba4-br100","Rating":5,"Description":"I had a great experience at Icon in Seattle! The team is extremely professional, kind, and efficient. The doctor and staff deliver care at a very high level, and the whole visit feels smooth from start to finish. I especially appreciate how quick the process is—my cleaning didn’t take long at all, but still felt very thorough. A truly pleasant and stress-free dental experience. Highly recommended!","Images":null,"When":""},{"Name":"Mario Rodriguez","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVIhDlaybz0WzLp-mi5kgYXGOZcpb8H5_zaDVjYI5ABMqincSni=s120-c-rp-mo-br100","Rating":5,"Description":"Really happy I found this office. The s