529-h298-k-no"},{"title":"Street View \u0026 360°","image":"https://streetviewpixels-pa.googleapis.com/v1/thumbnail?panoid=eyExSUYb9BpRxpqs7iZ-Ug\u0026cb_client=maps_sv.tactile.gps\u0026w=224\u0026h=298\u0026yaw=38.568832\u0026pitch=0\u0026thumbfov=100"}],"reservations":null,"order_online":null,"menu":{"link":"","source":""},"owner":{"id":"106125707016468075151","name":"Springbrook Dental (Owner)","link":"https://www.google.com/maps/contrib/106125707016468075151"},"complete_address":{"borough":"Hawthorne Hills","street":"4026 NE 55th St","city":"Seattle","postal_code":"98105","state":"Washington","country":"US"},"about":[{"id":"from_the_business","name":"From the business","options":[{"name":"Identifies as women-owned","enabled":true}]},{"id":"service_options","name":"Service options","options":[{"name":"Language assistance","enabled":false}]},{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible entrance","enabled":true},{"name":"Wheelchair accessible parking lot","enabled":true},{"name":"Wheelchair accessible restroom","enabled":true}]},{"id":"offerings","name":"Offerings","options":[{"name":"Cosmetic dentistry","enabled":true},{"name":"Pediatric care","enabled":true},{"name":"Sedation dentistry","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Restroom","enabled":true}]},{"id":"crowd","name":"Crowd","options":[{"name":"LGBTQ+ friendly","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointment required","enabled":true},{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Credit cards","enabled":false}]}],"user_reviews":[{"Name":"Lindsey B","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocLQzD6qgo1v9Vgn0aLQiBnnLh26VSqqDxyx_q30KOJs_tkB4g=s120-c-rp-mo-br100","Rating":2,"Description":"Do NOT recommend. Deceptive billing and poor communication.\n\nI had four fillings done, except only three were ever discussed or numbed. I didn't know about the fourth until I got the bill.\n\nThat bill was over DOUBLE the quote. Why? They estimated based on \"standard\" insurance coverage instead of actually checking mine.\n\nWhen I requested my account be deleted, I had to follow up multiple times to get any response.","Images":null,"When":""},{"Name":"Prabhjyot Gill","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKFhrxjJEu5_DFp_Ev0Ua2kHZRO-nbxBAW7o14ec2TCC2Cvyg=s120-c-rp-mo-br100","Rating":5,"Description":"I’ve been a patient of Springbrook dental for over 5 years. They take the time to listen to my needs and always provide the highest quality care.","Images":null,"When":""},{"Name":"Alyssa Mathe","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjVahNsiGCJdBAjWSJNjfRHCBYohsEfKwTrRjxlgpYiBu2N_2-AA=s120-c-rp-mo-br100","Rating":5,"Description":"I’ve been seeing Dr. Erke since 2017 and love Springbrook Dental.  She and her staff are incredibly kind and knowledgeable. They make going to the dentist as pleasant and as comfortable as it can be!  Highly recommend this practice!","Images":null,"When":""},{"Name":"Kelly Lundeen","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocI_FzsB3JEz2GJNJT3vQAfmAUlt30WqhvjYrR9Fggld5nX2jw=s120-c-rp-mo-ba2-br100","Rating":5,"Description":"Typically terrified of going to the dentist, but have always had positive experiences here. Being offered a blanket while in the chair was just the cherry on top!","Images":null,"When":""},{"Name":"Shurui Sun","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWKL13TxRuND5Hib1FSoUqP0fvaEGpUarvnrLqDrJV3M1YA3WuX=s120-c-rp-mo-br100","Rating":5,"Description":"The front desk is super professional and courteous. One time, I waited 30 minutes for my appointment, Love all the hygenists that I see regularly (especially Dianne!) Dr. Carpenter is great as well. My whole family comes here now!","Images":null,"When":""},{"Name":"Karla Beavo","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocLZD8-NeQHEHvweHahCamgur49WmyYwNTHngz1aif07kIS-Zg=s120-c-rp-mo-br100","Rating":5,"Description":"I absolutely love Springbrook Dental!  Every time I go in for my check up, I am always greeted by the friendly front office staff.  Every hygienist I have met has been wonderful, and Dr Carpenter always takes time to answer all my questions and I know I am in really good hands!  My whole family goes there and will continue for years to come. :)","Images":null,"When":""},{"Name":"Rebekah Kiehl","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocLldR6Xr6ZjnvGJvs1PZRiUwSyRUclss3iVzAIddxu8clAHWQ=s120-c-rp-mo-br100","Rating":5,"Description":"Dr. Carpenter is an excellent dentist and is great working with nervous kids and adults. My  five-year-old son was terrified of the dentist and after trying multiple pediatric dentists, someone recommended Dr.Carpenter. It was the first good experience my son had at the dentist. He is now 11 years old and actually looks forward to the dentist because he gets to watch T.V. and because Dr. Carpenter is so good with kids.\n\nI highly recommend Dr. Carpenter. She has a beautiful office and has great bedside manner. I’ve also been grateful that she will explain the treatment plan and the process so you understand what is happening.","Images":null,"When":""},{"Name":"Anna Dorati","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocITfn3-S4hIs2SJZFd-No6uaeRzVjTOZ7MddtCUxyrZ7HwETQ=s120-c-rp-mo-br100","Rating":5,"Description":"This has been the best dentist experience I’ve ever had. Everyone is always so sweet, smiling, non-judgmental and comforting!  The environment is so comforting with TVs and noise cancelling headphones for people who are a little scared like me. They’re been great during my pregnancy and post partum as well. I recommend Springbrook dental to all my friends!","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
