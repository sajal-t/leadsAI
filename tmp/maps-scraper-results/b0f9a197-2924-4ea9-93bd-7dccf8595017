ervations":null,"order_online":[{"link":"https://www.wedgwoodsmiles.com/","source":"wedgwoodsmiles.com"},{"link":"https://local.demandforce.com/b/wedgwoodsmilesseattle","source":"demandforce.com"}],"menu":{"link":"https://drive.google.com/file/d/1PWP_ZGGs6rf8OsWi7AtmiyzWcH1uTpgz/view","source":"drive.google.com"},"owner":{"id":"101107426781846464873","name":"Wedgwood Smiles (Owner)","link":"https://www.google.com/maps/contrib/101107426781846464873"},"complete_address":{"borough":"Wedgwood","street":"8014 35th Ave NE","city":"Seattle","postal_code":"98115","state":"Washington","country":"US"},"about":[{"id":"service_options","name":"Service options","options":[{"name":"Language assistance","enabled":false}]},{"id":"accessibility","name":"Accessibility","options":[{"name":"Wheelchair accessible entrance","enabled":true},{"name":"Wheelchair accessible parking lot","enabled":true},{"name":"Wheelchair accessible restroom","enabled":true}]},{"id":"offerings","name":"Offerings","options":[{"name":"Cosmetic dentistry","enabled":true},{"name":"Emergency services","enabled":true},{"name":"Pediatric care","enabled":true},{"name":"Sedation dentistry","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Gender-neutral restroom","enabled":true},{"name":"Restroom","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointment required","enabled":true},{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Payment plans","enabled":true},{"name":"Credit cards","enabled":false}]}],"user_reviews":[{"Name":"Sam Rock","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjXEfmLrbqJ-QJNZjNegQHhfzysqmJNdzdLNFeqMhKEcbxQLpfhP=s120-c-rp-mo-br100","Rating":5,"Description":"I have been coming to Wedgwood Smiles for years and hope to continue for years more. The doctors and staff are attentive and caring, communicate to me about my teeth, and give me clear advice and instructions. Cannot recommend Dr. Cruz and Dr. Lee enough!","Images":null,"When":""},{"Name":"David Elster","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocJymlIpeZvL8Nn-hQTrYJrfV1cVx33daJFuvl4zQ_Rx9uibVw=s120-c-rp-mo-br100","Rating":1,"Description":"I don’t typically leave negative reviews, but my experience at this dental office was extremely disappointing.\n\nI went in for a routine checkup with Dr. Cruz and was told I had a cavity, despite having no pain and seeing nothing concerning on the X-rays. I agreed to a standard filling. After the procedure, I immediately experienced new and persistent pain in that area that I had not had before.\n\nDr. Cruz assured me the pain would subside, but it did not. I returned for two additional visits so he could try to resolve the issue, but neither visit improved the pain. While he did ultimately refund the cost of the filling, he then recommended that I see an endodontist and made it clear he would not be responsible for the cost, despite the fact that the pain began only after his work.\n\nWhat made the situation more frustrating was that throughout these visits, he repeatedly tried to sell me a new night guard, even though I already have one and was actively dealing with unresolved pain.\n\nIn 35 years, I have never had a negative dental experience like this. Unfortunately, I would not recommend this practice based on my experience.","Images":null,"When":""},{"Name":"S","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocJX-OAPvoqRxo4IY1EIlHPrE6gxJZ7pzrb3zLO3sUOLmrU-xRo=s120-c-rp-mo-ba3-br100","Rating":1,"Description":"I’ve been a patient here for several years and always had cleanings fully covered under Delta Dental PPO. Without any notice to me, this office changed from PPO to Premier. I only found out after my visit, when I was billed an unexpected sum.\n\nThe office told me Delta “should have sent a letter,” but I never received anything. After talking with Delta Dental, they mentioned that it was the responsibility of the Dental Office (Wedgwood Smiles) to communicate the change in coverage to patients. However, I never received any communication.\n\nPatients should be clearly informed before appointments when a provider’s network status changes, especially when it affects cost. Unfortunately, that didn’t happen here, and I was left with a surprise bill and no help resolving it.","Images":null,"When":""},{"Name":"Kai Close","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWpKNAQHaSW8MRjA8tMX2ULWuT-02oN5Wgroeu1EUhkbEuIf-3x=s120-c-rp-mo-br100","Rating":5,"Description":"Great quality of care and you get the sense the clinic and everyone working there is like one big family that welcomes you in every visit. Dr. Cruz is thorough, understanding, and I can’t recommend him and his team enough.","Images":null,"When":""},{"Name":"Sadie Munson","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocIqbLJR04-BgpmQKSryDjxsxmQW4Dz04xIx5sbVsM7KAVIn-w=s120-c-rp-mo-br100","Rating":5,"Description":"Dr. Cruz and his staff are very caring, honest and professional, they really do care about your oral health. I used to be very nervous during dental visits in the past and I always needed laughing gas, but with Dr. Cruz I felt at ease for the first time without laughing gas. I would 100% recommend my family and closes friends to Dr. Cruz and his staff. 😊😊😊","Images":null,"When":""},{"Name":"Sidney Schwartz","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjXEDL04sQm96nR-d6AIHadGX2L5Ysc07lKfZyp_bzv-nsINwUU=s120-c-rp-mo-br100","Rating":5,"Description":"This dental office is amazing! The staff is super friendly, and the office is clean and modern. The dentists are not only skilled but also genuinely great people who listen and care. They use the latest tech for quick, painless treatments. Best dental experience ever – highly recommend!\n\nAlso- their staff continuous to get into accredited dental schools and is top notch!","Images":null,"When":""},{"Name":"Zhao Zhao","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjV0h4Y05HdM6fAdVE66uGRccE2kYm9izm5EVzro0T10RIEkZUe0=s120-c-rp-mo-br100","Rating":5,"Description":"My family has been with Dr Cruz for almost three years. Dr Cruz is highly professional with high quality treatment and great caring for the patient. He is very experienced in handling insurance and getting the best benefits for the patients. Another notable example is one of my family (no insurance) visited here experienced a sudden dental issue and within a day Dr Cruz was able to provide immediate examination and follow up recommendations with very reasonable fees. I would highly recommend going with Dr Cruz.","Images":null,"When":""},{"Name":"Adriana Newman","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjUL_TNIsz5bGCRVRe8zAU7mH72GB2ab1nmpGLI6ESeurkIvW4kO=s120-c-rp-mo-br100","Rating":5,"Description":"Dr. Cruz has been my dentist for the past five years, and I couldn’t be happier! His work is exceptional, and the entire staff is just as professional, friendly, and attentive.","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
