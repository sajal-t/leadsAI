name":"Emergency services","enabled":true},{"name":"Pediatric care","enabled":true}]},{"id":"amenities","name":"Amenities","options":[{"name":"Gender-neutral restroom","enabled":true},{"name":"Restroom","enabled":true}]},{"id":"crowd","name":"Crowd","options":[{"name":"LGBTQ+ friendly","enabled":true}]},{"id":"planning","name":"Planning","options":[{"name":"Appointment required","enabled":true},{"name":"Appointments recommended","enabled":true}]},{"id":"payments","name":"Payments","options":[{"name":"Checks","enabled":true},{"name":"Credit cards","enabled":true},{"name":"Debit cards","enabled":true},{"name":"NFC mobile payments","enabled":true},{"name":"Payment plans","enabled":true}]},{"id":"parking","name":"Parking","options":[{"name":"Paid parking garage","enabled":true}]}],"user_reviews":[{"Name":"Gordon Macdougall","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocJjZqv7pbb7Y46ZzwJgwJp4d7QHNTtL4B1gBSWAaa2XKfVYOA=s120-c-rp-mo-ba3-br100","Rating":5,"Description":"I have been a patient at Seattle Dental Associates for fifteen years. Dr. Baker is friendly, knowledgeable, an expert at dentistry, and works with a wonderful crew - two other great dentists and a passle of smart, convivial hygienists and other support staff.\nThey also treat my spouse, and treated her dear mother so kindly in her last years, gently working with her even as she became more...cantankerous.\nThis dentistry business is top notch.","Images":null,"When":""},{"Name":"Nancy Kasmar","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocIgSsyeWPSTQttEyv5p0FkCGh40BeA6xTd592Pk9WcQNWnMTg=s120-c-rp-mo-br100","Rating":5,"Description":"I really appreciate the personalized approach from everyone at Seattle Dental Associates. I am greeted by name when I walk in. Nick does a great job cleaning my teeth and makes it fun. Dr. Baker is easy to talk with and keeps up with the latest in dental technology (same day crowns!) They are the best!","Images":null,"When":""},{"Name":"Eleanor Payne","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocIQ2DquTphuTYEVg2f-Zr-l8QoRQEwFB0gCl47oGt1pYtCMyg=s120-c-rp-mo-br100","Rating":5,"Description":"I’m an admitted dental snob. I used to fly from wherever I lived to go to my original dentist. Enter Seattle Dental Associates: first the formidable Dr. Dexter Barnes and now Dr. Theron Baker. The whole office runs like clockwork, with each person nicer and more competent than the next. Helps that Dr. Baker has a very nice smile himself. Highest recommendation!","Images":null,"When":""},{"Name":"Bean Walton","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKqC5lp0EjmXx6c_pO3w65my9SbcBnLCSCO4Fi3OIGd2twN0A=s120-c-rp-mo-br100","Rating":5,"Description":"My appointment started on time, with a personable and professional hygienist (Nick). All went smoothly with clear explanations as needed. Dr Baker was his usual kind and reassuring self. All in all, a pleasant trip to the dentist!","Images":null,"When":""},{"Name":"Brian Chan","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjX1GTcQWbdVBcrN0dhWez21mH3SVU8kx642dlkKspCVYK7a1Tfr=s120-c-rp-mo-ba3-br100","Rating":5,"Description":"I’ve been a patient Seattle Dental Associates for over 15 years, and now my wife and children goes to him and his team too. The front desk staff is always welcoming, the hygienists are caring and thorough, and Dr. Baker takes the time to answer all my questions. I never feel rushed—just well cared for. And I've never felt pressured to do a procedure or treatment. I've been presented options and given time to think about it. I highly recommend Dr. Baker and his team.","Images":null,"When":""},{"Name":"Maria-Louise","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocL0c-lEg4DBQa2gUcCMsQMeaNOycriRhmnGEMx2CvLyM0MdUA=s120-c-rp-mo-br100","Rating":5,"Description":"Was referred to Seattle Dental Associates by an excellent endodontist team, after previous dentist retired. I've lived in several major cities, experiencing the help and guidance of several dentists. Dr. Baker and the team - dental assistants, dental hygienists, staff persons - are excellent in knowledge, care, thoughtfulness, experience, expertise.  I recommend them highly.  Thank you Seattle Dental Associates for all you do and have done for me.","Images":null,"When":""},{"Name":"Laurie Jacobson","ProfilePicture":"https://lh3.googleusercontent.com/a/ACg8ocKyEru5Y6Eh_xegS-hCIGXkel6ocSB-d2Z2NvjrNUHFuZRBJA=s120-c-rp-mo-br100","Rating":5,"Description":"Michaela at Dr Baker’s office is a fantastic hygienist. Very thorough and gentle and patient. Have been a patient of Dr Baker’s for over a decade and his bedside manner and kindness are appreciated!","Images":null,"When":""},{"Name":"Jasper DuBois","ProfilePicture":"https://lh3.googleusercontent.com/a-/ALV-UjWEiOkvqGBQ7u-kTaqDvQ9lHly4RaAdStr4kS8h9IRdqMLzc0nK=s120-c-rp-mo-br100","Rating":5,"Description":"I was in a major car accident last year and went to Seattle Dental Associates to make sure everything was ship shape. Everyone there was kind and went out of their way to accommodate my disabilities and made everything as painless as possible. I didn't even know gum numbing gel for dental appointments existed before today! Would highly recommend to anyone looking for a dentist.","Images":null,"When":""}],"user_reviews_extended":null,"emails":null}
